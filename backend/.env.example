DATABASE_URL=postgres://postgres:Mustaf%40123@localhost:5433/cad
# Use 3003 to match frontends (dispatcher, responder, responder-mobile). Default is 3001.
PORT=3003
JWT_SECRET=change-me
# Comma-separated public web app origins allowed to call the backend in production.
# Example: ALLOWED_ORIGINS=https://your-dispatcher.vercel.app,https://your-admin.vercel.app
ALLOWED_ORIGINS=
ALLOW_INSECURE_PASSWORD_RESET=1
LIVEKIT_RECORDING_ENABLED=0
LIVEKIT_RECORDING_OUTPUT=uploads
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
ARCGIS_PORTAL_URL=https://www.arcgis.com
ARCGIS_CLIENT_ID=your_arcgis_client_id
ARCGIS_CLIENT_SECRET=your_arcgis_client_secret

# Standalone Admin Portal credentials (used by /api/admin/auth/login)
ADMIN_PORTAL_USERNAME=admin
ADMIN_PORTAL_PASSWORD=Admin@12345
# Optional: separate JWT secret/expiry for admin-portal tokens
ADMIN_PORTAL_JWT_SECRET=
ADMIN_PORTAL_JWT_EXPIRES_IN=12h

# ---------------------------------------------------------------------------
# ArcGIS reverse-geocode (admin boundary + optional road name)
#
# Routing, ETA and live navigation were retired and will be rebuilt on top of
# ArcGIS Enterprise. The remaining ArcGIS dependencies are limited to
# reverse-geocoding incident pins for the dispatcher map.
# ---------------------------------------------------------------------------

# Optional: admin-boundary query endpoint used by /api/arcgis/reverse-geocode
# to populate province/district/sector/cell/village when the local Postgres
# `rwanda_admin_boundaries` table has no match. Must be an esrirw.rw (or same-deployment) URL when
# set so no admin data leaves the country.
ESRI_ADMIN_BOUNDARY_URL=https://esrirw.rw/server/rest/services/Hosted/Rwanda_Administrative_Boundaries1/FeatureServer/5/query

# Optional: in-country road-name reverse-geocode URL (Esri GeocodeServer).
# Leave unset to skip road-name lookup entirely (reverse-geocode will return
# only admin boundary fields). We intentionally do NOT fall back to public
# geocoders so that no coordinates leak off esrirw.rw.
ESRI_REVERSE_GEOCODE_URL=

# Optional: portal token for the in-country GeocodeServer above. The token
# never leaves the backend.
ESRI_REVERSE_GEOCODE_TOKEN=

# ---------------------------------------------------------------------------
# ArcGIS navigation routing (responder Navigate button)
# ---------------------------------------------------------------------------
# GPServer Closest Facility endpoint used by /api/arcgis/navigation/route.
NAV_ARCGIS_CLOSEST_FACILITY_URL=https://esrirw.rw/server/rest/services/Routing042026/NetworkAnalysis/GPServer/FindClosestFacilities
# Optional direct token. If unset, backend can mint token using portal creds below.
NAV_ARCGIS_TOKEN=
NAV_ARCGIS_PORTAL_URL=https://esrirw.rw/portal
NAV_ARCGIS_USERNAME=
NAV_ARCGIS_PASSWORD=
NAV_ARCGIS_TOKEN_EXPIRATION_MINUTES=120
NAV_ARCGIS_POLL_INTERVAL_MS=750
NAV_ARCGIS_POLL_TIMEOUT_MS=18000
