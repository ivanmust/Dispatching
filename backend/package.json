{
  "name": "cad-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "reset-db": "npx ts-node --transpile-only scripts/reset-db.ts",
    "backfill:incident-timeline": "npx ts-node --transpile-only scripts/backfill-incident-timeline.ts",
    "backfill:responder-units": "npx ts-node --transpile-only scripts/backfill-responder-units.ts",
    "dev": "tsx watch src/index.ts",
    "migrate": "ts-node --transpile-only src/migrate.ts",
    "migrate:prod": "node dist/migrate.js",
    "migrate:operator-supervisor": "ts-node --transpile-only scripts/migrate-operator-supervisor.ts",
    "check-schema": "ts-node --transpile-only scripts/check-schema.ts",
    "arcgis:import-admin": "ts-node --transpile-only scripts/import-rwanda-admin-boundaries.ts",
    "cleanup:demo-data": "ts-node --transpile-only scripts/cleanup-demo-test-data.ts",
    "cleanup:e2e-lifecycle": "ts-node --transpile-only scripts/delete-e2e-lifecycle-data.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "redis": "^5.11.0",
    "socket.io": "^4.8.1",
    "twilio": "^5.3.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
