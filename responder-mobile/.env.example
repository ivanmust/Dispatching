# Leave EXPO_PUBLIC_API_BASE unset in Expo Go dev.
# The app auto-derives API base from Metro host to avoid LAN mismatch issues.
EXPO_PUBLIC_MAP_PROVIDER=esri
EXPO_PUBLIC_ESRI_MAP_URL=https://esrirw.rw/portal/apps/mapviewer/index.html?webmap=3e190cfba7fd4d1f8c9600cc072a6d15
# Optional ArcGIS Portal OAuth app id (register redirect URI to your app URL). Helps persist portal sign-in for secured web maps/layers.
EXPO_PUBLIC_ARCGIS_PORTAL_APP_ID=
# When true (default), navigation map uses a lighter basemap and fewer overlays. Set to "false" for full satellite + layers.
EXPO_PUBLIC_ESRI_MAP_NAVIGATION_MINIMAL=

# Navigation tuning (optional overrides; defaults are used when omitted)
EXPO_PUBLIC_NAV_HOME_LOCATION_SYNC_MS=4000
EXPO_PUBLIC_NAV_ROUTE_REFRESH_MIN_INTERVAL_MS=7000
EXPO_PUBLIC_NAV_OFF_ROUTE_CONSECUTIVE_SAMPLES=3
EXPO_PUBLIC_NAV_ARRIVAL_METERS=28
EXPO_PUBLIC_NAV_ARRIVAL_AUTOSTOP_DELAY_MS=1200
EXPO_PUBLIC_NAV_GPS_WEAK_AFTER_MS=15000
EXPO_PUBLIC_NAV_DEAD_RECKON_AFTER_MS=4000
EXPO_PUBLIC_NAV_DEAD_RECKON_MAX_MS=45000
EXPO_PUBLIC_NAV_MAPMATCH_MIN_SNAP_METERS=20
EXPO_PUBLIC_NAV_MAPMATCH_MAX_SNAP_METERS=70
EXPO_PUBLIC_NAV_MAPMATCH_SNAP_ACCURACY_MULTIPLIER=1.2
EXPO_PUBLIC_NAV_MAPMATCH_UNSTABLE_ACCURACY_METERS=90
EXPO_PUBLIC_NAV_MAPMATCH_MIN_OFFROUTE_METERS=26
EXPO_PUBLIC_NAV_MAPMATCH_MAX_OFFROUTE_METERS=90
EXPO_PUBLIC_NAV_MANEUVER_MATCH_METERS=180
EXPO_PUBLIC_NAV_MAPMATCH_OFFROUTE_ACCURACY_MULTIPLIER=1.7
EXPO_PUBLIC_NAV_CAMERA_NEAR_TURN_METERS=80
EXPO_PUBLIC_NAV_CAMERA_APPROACH_TURN_METERS=200
EXPO_PUBLIC_NAV_CAMERA_LONG_STRAIGHT_METERS=450
EXPO_PUBLIC_NAV_CAMERA_VERY_LONG_STRAIGHT_METERS=900
EXPO_PUBLIC_NAV_CAMERA_HIGH_SPEED_MPS=18
EXPO_PUBLIC_NAV_CAMERA_MEDIUM_SPEED_MPS=12
EXPO_PUBLIC_NAV_BANNER_IMMINENT_METERS=80
EXPO_PUBLIC_NAV_BANNER_SOON_METERS=220
EXPO_PUBLIC_NAV_HAPTICS_IMMINENT_COOLDOWN_MS=12000
